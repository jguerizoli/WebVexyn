// Pipeline webvexyn-dev (branch develop) — deploy MANUAL.
// Idêntico ao prod, mas opera sobre o serviço webvexyn-dev.
pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timeout(time: 10, unit: 'MINUTES')
    }

    environment {
        COMPOSE_DIR = '/var/www/webvexyn/docker'
        SERVICE     = 'webvexyn-dev'
    }

    stages {
        stage('Build') {
            steps {
                sh 'docker compose --project-directory ${COMPOSE_DIR} --env-file ${COMPOSE_DIR}/.env -f ${COMPOSE_DIR}/docker-compose.yml build --no-cache ${SERVICE}'
            }
        }
        stage('Deploy') {
            steps {
                sh 'docker compose --project-directory ${COMPOSE_DIR} --env-file ${COMPOSE_DIR}/.env -f ${COMPOSE_DIR}/docker-compose.yml up -d ${SERVICE}'
            }
        }
        stage('Health Check') {
            steps {
                sh '''
                    for i in $(seq 1 12); do
                        status=$(docker inspect --format='{{.State.Health.Status}}' ${SERVICE} 2>/dev/null || echo "unknown")
                        echo "Tentativa $i: ${SERVICE} -> $status"
                        [ "$status" = "healthy" ] && exit 0
                        sleep 5
                    done
                    echo "Container não ficou healthy a tempo"; exit 1
                '''
            }
        }
        stage('Cleanup') {
            steps {
                sh 'docker image prune -f'
            }
        }
    }

    post {
        success { echo "Deploy de ${SERVICE} concluído com sucesso." }
        failure { echo "Falha no deploy de ${SERVICE} — checar logs." }
    }
}
